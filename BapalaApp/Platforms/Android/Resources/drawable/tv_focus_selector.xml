<?xml version="1.0" encoding="utf-8"?>
<!-- TV D-pad focus selector — drawn by Android TV when focus lands on any
     view that sets android:background="@drawable/tv_focus_selector"       -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#2ae50914" />
            <stroke android:width="3dp" android:color="#e50914" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
</selector>
