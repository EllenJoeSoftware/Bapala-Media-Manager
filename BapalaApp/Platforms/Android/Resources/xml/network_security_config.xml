<?xml version="1.0" encoding="utf-8"?>
<!--
    Allows cleartext HTTP traffic to local network hosts.
    The Bapala server runs on HTTP (not HTTPS) by default on the local LAN.
    This is safe because the traffic never leaves the private network.
    Replace with HTTPS + a proper certificate for internet-facing deployments.
-->
<network-security-config>
    <!-- Trust system CAs for all other traffic -->
    <base-config cleartextTrafficPermitted="false" />

    <!-- Allow HTTP to private / LAN IP ranges -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">192.168.0.0</domain>
        <domain includeSubdomains="true">192.168.1.0</domain>
        <domain includeSubdomains="true">10.0.0.0</domain>
        <domain includeSubdomains="true">172.16.0.0</domain>
        <domain includeSubdomains="true">localhost</domain>
    </domain-config>
</network-security-config>
