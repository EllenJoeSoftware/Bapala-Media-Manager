<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="BapalaApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.FlyoutBehavior="Disabled"
    BackgroundColor="{StaticResource SurfaceColor}"
    ForegroundColor="{StaticResource TextColor}"
    TitleColor="{StaticResource TextColor}"
    UnselectedColor="{StaticResource Text2Color}"
    TabBarBackgroundColor="{StaticResource SurfaceColor}"
    TabBarForegroundColor="{StaticResource AccentColor}"
    TabBarUnselectedColor="{StaticResource Text2Color}"
    TabBarTitleColor="{StaticResource TextColor}">

    <TabBar>
        <!-- Content is set from code-behind via DI (AppShell.xaml.cs) so that
             MAUI never calls Activator.CreateInstance on LibraryPage, which has
             no parameterless constructor. -->
        <ShellContent
            x:Name="LibraryContent"
            Title="Library"
            Route="library" />
    </TabBar>

    <!-- PlayerPage is pushed on top of the shell, not a tab -->

</Shell>
