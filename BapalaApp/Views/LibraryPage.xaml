<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="BapalaApp.Views.LibraryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:BapalaApp.ViewModels"
    xmlns:models="clr-namespace:BapalaApp.Models"
    x:DataType="vm:LibraryViewModel"
    Title="Bapala"
    BackgroundColor="{StaticResource BgColor}">

    <Shell.TitleView>
        <Label
            Text="Bapala"
            FontSize="22"
            FontAttributes="Bold"
            TextColor="{StaticResource AccentColor}"
            VerticalOptions="Center"
            Margin="8,0" />
    </Shell.TitleView>

    <Grid RowDefinitions="Auto, Auto, Auto, *, Auto">

        <!-- ── Row 0: Search bar ─────────────────────────────────────────── -->
        <SearchBar
            Grid.Row="0"
            Text="{Binding SearchText}"
            Placeholder="Search titles…"
            SearchCommand="{Binding SearchCommand}"
            BackgroundColor="{StaticResource SurfaceColor}"
            Margin="0" />

        <!-- ── Row 1: TMDB refresh progress bar (visible while running) ──── -->
        <Grid
            Grid.Row="1"
            RowDefinitions="Auto, Auto"
            IsVisible="{Binding IsTmdbRefreshing}"
            BackgroundColor="{StaticResource SurfaceColor}"
            Padding="12,6">

            <Grid Grid.Row="0" ColumnDefinitions="*, Auto">
                <Label
                    Grid.Column="0"
                    Text="{Binding TmdbStatusText}"
                    FontSize="12"
                    TextColor="{StaticResource Text2Color}"
                    VerticalOptions="Center"
                    LineBreakMode="TailTruncation" />
                <Label
                    Grid.Column="1"
                    Text="{Binding TmdbProgressLabel}"
                    FontSize="12"
                    FontAttributes="Bold"
                    TextColor="{StaticResource AccentColor}"
                    VerticalOptions="Center"
                    Margin="8,0,0,0" />
            </Grid>

            <ProgressBar
                Grid.Row="1"
                Progress="{Binding TmdbProgressFraction}"
                ProgressColor="{StaticResource AccentColor}"
                BackgroundColor="{StaticResource Surface2Color}"
                Margin="0,4,0,0" />

        </Grid>

        <!-- ── Row 2: Filter chips ───────────────────────────────────────── -->
        <!--
            We bind BackgroundColor + TextColor directly on each Button rather than
            binding the Style property via a converter.  Binding an entire Style object
            is unreliable with compiled bindings; individual visual-property bindings are
            fully supported and type-safe.
        -->
        <ScrollView
            Grid.Row="2"
            Orientation="Horizontal"
            HorizontalScrollBarVisibility="Never"
            BackgroundColor="{StaticResource SurfaceColor}"
            Padding="12,8">
            <HorizontalStackLayout Spacing="8">

                <Button Text="All"
                        Command="{Binding ClearFiltersCommand}"
                        Style="{StaticResource TvChipButton}"
                        BackgroundColor="{Binding AllActive,       Converter={x:StaticResource BoolToChipBgConverter}}"
                        TextColor="{Binding AllActive,             Converter={x:StaticResource BoolToChipFgConverter}}" />

                <Button Text="Movies"
                        Command="{Binding SetFilterCommand}" CommandParameter="Movie"
                        Style="{StaticResource TvChipButton}"
                        BackgroundColor="{Binding MoviesActive,    Converter={x:StaticResource BoolToChipBgConverter}}"
                        TextColor="{Binding MoviesActive,          Converter={x:StaticResource BoolToChipFgConverter}}" />

                <Button Text="Series"
                        Command="{Binding SetFilterCommand}" CommandParameter="Series"
                        Style="{StaticResource TvChipButton}"
                        BackgroundColor="{Binding SeriesActive,    Converter={x:StaticResource BoolToChipBgConverter}}"
                        TextColor="{Binding SeriesActive,          Converter={x:StaticResource BoolToChipFgConverter}}" />

                <Button Text="Docs"
                        Command="{Binding SetFilterCommand}" CommandParameter="Documentary"
                        Style="{StaticResource TvChipButton}"
                        BackgroundColor="{Binding DocsActive,      Converter={x:StaticResource BoolToChipBgConverter}}"
                        TextColor="{Binding DocsActive,            Converter={x:StaticResource BoolToChipFgConverter}}" />

                <Button Text="Education"
                        Command="{Binding SetFilterCommand}" CommandParameter="Education"
                        Style="{StaticResource TvChipButton}"
                        BackgroundColor="{Binding EducationActive, Converter={x:StaticResource BoolToChipBgConverter}}"
                        TextColor="{Binding EducationActive,       Converter={x:StaticResource BoolToChipFgConverter}}" />

                <Button Text="Music"
                        Command="{Binding SetFilterCommand}" CommandParameter="MusicVideo"
                        Style="{StaticResource TvChipButton}"
                        BackgroundColor="{Binding MusicActive,     Converter={x:StaticResource BoolToChipBgConverter}}"
                        TextColor="{Binding MusicActive,           Converter={x:StaticResource BoolToChipFgConverter}}" />

                <Button Text="♥ Favorites"
                        Command="{Binding ToggleFavoritesCommand}"
                        Style="{StaticResource TvChipButton}"
                        BackgroundColor="{Binding FavoritesActive, Converter={x:StaticResource BoolToChipBgConverter}}"
                        TextColor="{Binding FavoritesActive,       Converter={x:StaticResource BoolToChipFgConverter}}" />

                <!-- Divider -->
                <BoxView WidthRequest="1" HeightRequest="20" Color="{StaticResource Surface2Color}" VerticalOptions="Center" Margin="4,0" />

                <!-- TMDB refresh button -->
                <Button
                    Text="⟳ TMDB"
                    Command="{Binding RefreshAllTmdbCommand}"
                    IsEnabled="{Binding IsTmdbRefreshing, Converter={x:StaticResource InvertedBoolConverter}}"
                    Style="{StaticResource TvChipButton}"
                    BackgroundColor="{StaticResource Surface2Color}"
                    TextColor="{StaticResource AccentColor}"
                    ToolTipProperties.Text="Fetch missing posters, descriptions and ratings from TMDB" />

            </HorizontalStackLayout>
        </ScrollView>

        <!-- ── Row 3: Media grid ─────────────────────────────────────────── -->
        <RefreshView
            Grid.Row="3"
            Command="{Binding RefreshCommand}"
            IsRefreshing="{Binding IsRefreshing}">

            <CollectionView
                x:Name="MediaGrid"
                ItemsSource="{Binding Items}"
                SelectionMode="Single"
                EmptyView="No media found. Try scanning or adjusting filters.">

                <CollectionView.ItemsLayout>
                    <GridItemsLayout
                        Orientation="Vertical"
                        Span="4"
                        HorizontalItemSpacing="12"
                        VerticalItemSpacing="12" />
                </CollectionView.ItemsLayout>

                <CollectionView.Header>
                    <VerticalStackLayout Spacing="0">

                        <!-- Loading indicator -->
                        <ActivityIndicator
                            IsRunning="{Binding IsBusy}"
                            IsVisible="{Binding IsBusy}"
                            Margin="0,16"
                            HorizontalOptions="Center" />

                        <!-- ── Stats row ───────────────────────────────────── -->
                        <Grid
                            IsVisible="{Binding HasStats}"
                            ColumnDefinitions="*,*,*,*"
                            Padding="12,12,12,4"
                            ColumnSpacing="8">

                            <Border Grid.Column="0" Style="{StaticResource StatTile}">
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="{Binding Stats.TotalItems}" Style="{StaticResource StatNumber}" />
                                    <Label Text="Items" Style="{StaticResource StatLabel}" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource StatTile}">
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="{Binding Stats.Movies}" Style="{StaticResource StatNumber}" />
                                    <Label Text="Movies" Style="{StaticResource StatLabel}" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource StatTile}">
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="{Binding Stats.Series}" Style="{StaticResource StatNumber}" />
                                    <Label Text="Series" Style="{StaticResource StatLabel}" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Column="3" Style="{StaticResource StatTile}">
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="{Binding Stats.TotalDurationDisplay}" Style="{StaticResource StatNumber}" />
                                    <Label Text="Total" Style="{StaticResource StatLabel}" />
                                </VerticalStackLayout>
                            </Border>

                        </Grid>

                        <!-- ── Continue Watching ──────────────────────────── -->
                        <VerticalStackLayout
                            IsVisible="{Binding HasContinueWatching}"
                            Padding="0,8,0,4"
                            Spacing="0">

                            <Label
                                Text="▶  Continue Watching"
                                FontSize="14"
                                FontAttributes="Bold"
                                TextColor="{StaticResource TextColor}"
                                Margin="12,0,12,8" />

                            <ScrollView
                                Orientation="Horizontal"
                                HorizontalScrollBarVisibility="Never">

                                <HorizontalStackLayout
                                    Spacing="10"
                                    Padding="12,0">

                                    <BindableLayout.ItemsSource>
                                        <Binding Path="ContinueWatching" />
                                    </BindableLayout.ItemsSource>

                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="models:ContinueWatchingItem">
                                            <Border
                                                WidthRequest="140"
                                                StrokeShape="RoundRectangle 10"
                                                Stroke="{StaticResource Surface2Color}"
                                                BackgroundColor="{StaticResource SurfaceColor}">

                                                <Grid>
                                                    <Grid.GestureRecognizers>
                                                        <TapGestureRecognizer Tapped="OnContinueWatchingTapped" />
                                                    </Grid.GestureRecognizers>

                                                    <Grid RowDefinitions="110, Auto, 4">

                                                        <!-- Poster -->
                                                        <Image
                                                            Grid.Row="0"
                                                            Aspect="AspectFill"
                                                            BackgroundColor="{StaticResource Surface2Color}">
                                                            <Image.Source>
                                                                <UriImageSource
                                                                    Uri="{Binding PosterPath}"
                                                                    CacheValidity="7.00:00:00" />
                                                            </Image.Source>
                                                        </Image>

                                                        <!-- Title + remaining -->
                                                        <VerticalStackLayout
                                                            Grid.Row="1"
                                                            Padding="8,6"
                                                            Spacing="2">
                                                            <Label
                                                                Text="{Binding Title}"
                                                                FontSize="12"
                                                                FontAttributes="Bold"
                                                                TextColor="{StaticResource TextColor}"
                                                                LineBreakMode="TailTruncation"
                                                                MaxLines="2" />
                                                            <Label
                                                                Text="{Binding RemainingLabel}"
                                                                FontSize="10"
                                                                TextColor="{StaticResource AccentColor}" />
                                                        </VerticalStackLayout>

                                                        <!-- Progress bar -->
                                                        <ProgressBar
                                                            Grid.Row="2"
                                                            Progress="{Binding ProgressFraction}"
                                                            ProgressColor="{StaticResource AccentColor}"
                                                            BackgroundColor="{StaticResource Surface2Color}" />

                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>

                                </HorizontalStackLayout>
                            </ScrollView>

                        </VerticalStackLayout>

                        <!-- Section label for the main grid -->
                        <Label
                            Text="All Media"
                            FontSize="14"
                            FontAttributes="Bold"
                            TextColor="{StaticResource TextColor}"
                            Margin="12,12,12,4"
                            IsVisible="{Binding HasContinueWatching}" />

                    </VerticalStackLayout>
                </CollectionView.Header>

                <!--
                    Commands that need the parent LibraryViewModel are wired in code-behind
                    (LibraryPage.xaml.cs) via TapGestureRecognizer and Button.Clicked events.
                    This avoids RelativeSource AncestorType inside a DataTemplate, which is
                    fragile because the visual tree may not be fully built when a recycled cell
                    is first bound.
                -->
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:MediaItem">
                        <Grid Padding="4">
                            <Grid.GestureRecognizers>
                                <!-- Play handled in code-behind via MediaGrid_Tapped -->
                                <TapGestureRecognizer Tapped="OnCardTapped" />
                            </Grid.GestureRecognizers>

                            <Border Style="{StaticResource TvCardFrame}">
                                <Grid RowDefinitions="200, Auto">

                                    <!-- Poster image -->
                                    <Image
                                        Grid.Row="0"
                                        Aspect="AspectFill"
                                        BackgroundColor="{StaticResource Surface2Color}">
                                        <Image.Source>
                                            <UriImageSource
                                                Uri="{Binding PosterPath}"
                                                CacheValidity="7.00:00:00" />
                                        </Image.Source>
                                    </Image>

                                    <!-- Overlay: favorite button top-right — Clicked wired in code-behind -->
                                    <Button
                                        Grid.Row="0"
                                        Text="{Binding FavIcon}"
                                        TextColor="{StaticResource AccentColor}"
                                        BackgroundColor="#99000000"
                                        CornerRadius="16"
                                        Padding="6,2"
                                        FontSize="16"
                                        WidthRequest="36"
                                        HeightRequest="36"
                                        VerticalOptions="Start"
                                        HorizontalOptions="End"
                                        Margin="6"
                                        Clicked="OnFavoriteClicked" />

                                    <!-- Title + meta below poster -->
                                    <VerticalStackLayout Grid.Row="1" Padding="8,6,8,8" Spacing="3">
                                        <Label
                                            Text="{Binding Title}"
                                            FontSize="13"
                                            FontAttributes="Bold"
                                            TextColor="{StaticResource TextColor}"
                                            LineBreakMode="TailTruncation"
                                            MaxLines="2" />
                                        <Label
                                            Text="{Binding DisplayMeta}"
                                            Style="{StaticResource SubLabel}" />
                                        <Label
                                            Text="{Binding RatingDisplay}"
                                            TextColor="{StaticResource AccentColor}"
                                            FontSize="11"
                                            IsVisible="{Binding Rating, Converter={x:StaticResource NotNullConverter}}" />
                                    </VerticalStackLayout>

                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- ── Row 4: Pagination ─────────────────────────────────────────── -->
        <Grid
            Grid.Row="4"
            ColumnDefinitions="Auto,*,Auto"
            Padding="16,8"
            BackgroundColor="{StaticResource SurfaceColor}"
            IsVisible="{Binding TotalItems, Converter={x:StaticResource GreaterThanZeroConverter}}">

            <Button
                Grid.Column="0"
                Text="← Prev"
                Command="{Binding PreviousPageCommand}"
                IsEnabled="{Binding HasPreviousPage}"
                Style="{StaticResource TvChipButton}" />

            <Label
                Grid.Column="1"
                Text="{Binding PageLabel}"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                FontSize="12"
                TextColor="{StaticResource Text2Color}" />

            <Button
                Grid.Column="2"
                Text="Next →"
                Command="{Binding NextPageCommand}"
                IsEnabled="{Binding HasNextPage}"
                Style="{StaticResource TvChipButton}" />
        </Grid>

    </Grid>
</ContentPage>
