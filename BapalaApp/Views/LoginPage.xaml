<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="BapalaApp.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:BapalaApp.ViewModels"
    xmlns:models="clr-namespace:BapalaApp.Models"
    x:DataType="vm:LoginViewModel"
    Title="{Binding Title}"
    BackgroundColor="{StaticResource BgColor}"
    Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout
            Padding="32"
            Spacing="0"
            VerticalOptions="Center"
            MinimumHeightRequest="600">

            <!-- ── Logo / brand ── -->
            <Label
                Text="Bapala"
                FontSize="40"
                FontAttributes="Bold"
                TextColor="{StaticResource AccentColor}"
                HorizontalOptions="Center"
                Margin="0,0,0,8" />
            <Label
                Text="Your personal media server"
                Style="{StaticResource SubLabel}"
                HorizontalOptions="Center"
                Margin="0,0,0,32" />

            <!-- ══════════════════════════════════════════════════════════════ -->
            <!-- ── LAN Discovery panel ── -->
            <!-- ══════════════════════════════════════════════════════════════ -->
            <Border
                Padding="16"
                Margin="0,0,0,24"
                BackgroundColor="#1E1E2E"
                Stroke="#2A2A3C"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 14">
                <VerticalStackLayout Spacing="12">

                    <!-- Header row: icon + label + scan spinner -->
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                        <Label
                            Grid.Column="0"
                            Text="📡"
                            FontSize="18"
                            VerticalOptions="Center" />
                        <Label
                            Grid.Column="1"
                            Text="{Binding ScanStatus}"
                            Style="{StaticResource SubLabel}"
                            VerticalOptions="Center"
                            FontSize="13" />
                        <!-- Spinner while scanning -->
                        <ActivityIndicator
                            Grid.Column="2"
                            IsRunning="{Binding IsScanning}"
                            IsVisible="{Binding IsScanning}"
                            WidthRequest="20"
                            HeightRequest="20"
                            VerticalOptions="Center" />
                        <!-- Rescan button when idle -->
                        <Button
                            Grid.Column="2"
                            Text="↻"
                            Command="{Binding RescanCommand}"
                            IsVisible="{Binding IsScanning, Converter={x:StaticResource InvertedBoolConverter}}"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource AccentColor}"
                            FontSize="18"
                            Padding="4"
                            WidthRequest="32"
                            HeightRequest="32"
                            VerticalOptions="Center" />
                    </Grid>

                    <!-- Discovered server list — hidden when empty -->
                    <CollectionView
                        ItemsSource="{Binding DiscoveredServers}"
                        IsVisible="{Binding DiscoveredServers.Count, Converter={x:StaticResource IntToBoolConverter}}"
                        SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:DiscoveredServer">
                                <Border
                                    Padding="14,12"
                                    Margin="0,4,0,0"
                                    BackgroundColor="#252538"
                                    Stroke="#3A3A50"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10">
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroupList>
                                            <VisualStateGroup x:Name="CommonStates">
                                                <VisualState x:Name="Normal">
                                                    <VisualState.Setters>
                                                        <Setter Property="Stroke" Value="#3A3A50" />
                                                        <Setter Property="Scale"  Value="1.0" />
                                                    </VisualState.Setters>
                                                </VisualState>
                                                <VisualState x:Name="Focused">
                                                    <VisualState.Setters>
                                                        <Setter Property="Stroke"          Value="{StaticResource FocusColor}" />
                                                        <Setter Property="StrokeThickness" Value="3" />
                                                        <Setter Property="Scale"           Value="1.03" />
                                                        <Setter Property="BackgroundColor" Value="{StaticResource FocusBgColor}" />
                                                    </VisualState.Setters>
                                                </VisualState>
                                            </VisualStateGroup>
                                        </VisualStateGroupList>
                                    </VisualStateManager.VisualStateGroups>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LoginViewModel}}, Path=SelectServerCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                                            <Label
                                                Text="{Binding Name}"
                                                FontAttributes="Bold"
                                                FontSize="14"
                                                TextColor="White" />
                                            <Label
                                                Text="{Binding BaseUrl}"
                                                FontSize="12"
                                                TextColor="#9090B0" />
                                        </VerticalStackLayout>
                                        <Label
                                            Grid.Column="1"
                                            Text="Connect →"
                                            FontSize="12"
                                            FontAttributes="Bold"
                                            TextColor="{StaticResource AccentColor}"
                                            VerticalOptions="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </Border>

            <!-- ── Divider ── -->
            <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="10" Margin="0,0,0,20">
                <BoxView Grid.Column="0" HeightRequest="1" BackgroundColor="#2A2A3C" VerticalOptions="Center" />
                <Label Grid.Column="1" Text="or enter manually" FontSize="11" TextColor="#555570" />
                <BoxView Grid.Column="2" HeightRequest="1" BackgroundColor="#2A2A3C" VerticalOptions="Center" />
            </Grid>

            <!-- ══════════════════════════════════════════════════════════════ -->
            <!-- ── Manual login form ── -->
            <!-- ══════════════════════════════════════════════════════════════ -->

            <!-- Server URL -->
            <Label Text="Server Address" Style="{StaticResource SubLabel}" Margin="0,0,0,6" />
            <Entry
                Text="{Binding ServerUrl}"
                Placeholder="http://192.168.1.5:8484"
                Keyboard="Url"
                ReturnType="Next"
                Margin="0,0,0,16" />

            <!-- Username -->
            <Label Text="Username" Style="{StaticResource SubLabel}" Margin="0,0,0,6" />
            <Entry
                Text="{Binding Username}"
                Placeholder="admin"
                ReturnType="Next"
                Margin="0,0,0,16" />

            <!-- Password -->
            <Label Text="Password" Style="{StaticResource SubLabel}" Margin="0,0,0,6" />
            <Entry
                Text="{Binding Password}"
                Placeholder="••••••••"
                IsPassword="True"
                ReturnType="Go"
                ReturnCommand="{Binding LoginCommand}"
                Margin="0,0,0,24" />

            <!-- Error message -->
            <Label
                Text="{Binding ErrorText}"
                TextColor="{StaticResource AccentColor}"
                FontSize="13"
                IsVisible="{Binding ErrorText, Converter={x:StaticResource StringNotEmptyConverter}}"
                Margin="0,0,0,12" />

            <!-- Sign In button -->
            <Button
                Text="Sign In"
                Command="{Binding LoginCommand}"
                Style="{StaticResource TvButton}"
                IsEnabled="{Binding IsNotBusy}" />

            <!-- Activity indicator -->
            <ActivityIndicator
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                Margin="0,16,0,0"
                HorizontalOptions="Center" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
