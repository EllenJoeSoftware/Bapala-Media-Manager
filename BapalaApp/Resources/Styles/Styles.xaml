<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:conv="clr-namespace:BapalaApp.Converters">

    <!-- ── Value converters (referenced in XAML pages) ──────────────────── -->
    <conv:StringNotEmptyConverter  x:Key="StringNotEmptyConverter" />
    <conv:NotNullConverter         x:Key="NotNullConverter" />
    <conv:GreaterThanZeroConverter x:Key="GreaterThanZeroConverter" />
    <conv:BoolToChipStyleConverter x:Key="BoolToChipStyleConverter" />
    <!-- Per-property chip colour converters — safer than binding the Style object -->
    <conv:BoolToChipBgConverter    x:Key="BoolToChipBgConverter" />
    <conv:BoolToChipFgConverter    x:Key="BoolToChipFgConverter" />
    <!-- Discovery panel converters -->
    <conv:IntToBoolConverter       x:Key="IntToBoolConverter" />
    <conv:InvertedBoolConverter    x:Key="InvertedBoolConverter" />

    <!-- ── Page / shell ──────────────────────────────────────────────────── -->
    <Style TargetType="ContentPage" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{StaticResource BgColor}" />
    </Style>
    <Style TargetType="NavigationPage">
        <Setter Property="BarBackgroundColor" Value="{StaticResource SurfaceColor}" />
        <Setter Property="BarTextColor"       Value="{StaticResource TextColor}" />
    </Style>

    <!-- ── Typography ────────────────────────────────────────────────────── -->
    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource TextColor}" />
    </Style>
    <Style x:Key="SubLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource Text2Color}" />
        <Setter Property="FontSize"  Value="12" />
    </Style>

    <!-- ── Inputs ────────────────────────────────────────────────────────── -->
    <Style TargetType="Entry">
        <Setter Property="BackgroundColor"   Value="{StaticResource Surface2Color}" />
        <Setter Property="TextColor"         Value="{StaticResource TextColor}" />
        <Setter Property="PlaceholderColor"  Value="{StaticResource Text2Color}" />
        <Setter Property="ClearButtonVisibility" Value="WhileEditing" />
    </Style>
    <Style TargetType="SearchBar">
        <Setter Property="BackgroundColor"  Value="{StaticResource Surface2Color}" />
        <Setter Property="TextColor"        Value="{StaticResource TextColor}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource Text2Color}" />
        <Setter Property="CancelButtonColor" Value="{StaticResource Text2Color}" />
    </Style>

    <!-- ── Buttons ────────────────────────────────────────────────────────── -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource AccentColor}" />
        <Setter Property="TextColor"       Value="White" />
        <Setter Property="CornerRadius"    Value="6" />
        <Setter Property="FontAttributes"  Value="Bold" />
        <Setter Property="HeightRequest"   Value="48" />
    </Style>
    <Style x:Key="ChipButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Surface2Color}" />
        <Setter Property="TextColor"       Value="{StaticResource Text2Color}" />
        <Setter Property="CornerRadius"    Value="20" />
        <Setter Property="FontSize"        Value="13" />
        <Setter Property="Padding"         Value="14,6" />
        <Setter Property="HeightRequest"   Value="34" />
    </Style>
    <Style x:Key="ActiveChipButton" TargetType="Button" BasedOn="{StaticResource ChipButton}">
        <Setter Property="BackgroundColor" Value="{StaticResource AccentColor}" />
        <Setter Property="TextColor"       Value="White" />
    </Style>

    <!-- ── Cards ─────────────────────────────────────────────────────────── -->
    <Style x:Key="CardFrame" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource Surface2Color}" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="StrokeShape"     Value="RoundRectangle 8" />
    </Style>

    <!-- ── Misc ──────────────────────────────────────────────────────────── -->
    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{StaticResource AccentColor}" />
    </Style>
    <Style TargetType="RefreshView">
        <Setter Property="RefreshColor" Value="{StaticResource AccentColor}" />
    </Style>

    <!-- ── Stats tiles ───────────────────────────────────────────────────── -->
    <Style x:Key="StatTile" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceColor}" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="StrokeShape"     Value="RoundRectangle 8" />
        <Setter Property="Padding"         Value="8,8" />
        <Setter Property="HorizontalOptions" Value="Fill" />
    </Style>
    <Style x:Key="StatNumber" TargetType="Label">
        <Setter Property="FontSize"       Value="18" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor"      Value="{StaticResource AccentColor}" />
        <Setter Property="HorizontalOptions" Value="Center" />
    </Style>
    <Style x:Key="StatLabel" TargetType="Label">
        <Setter Property="FontSize"       Value="10" />
        <Setter Property="TextColor"      Value="{StaticResource Text2Color}" />
        <Setter Property="HorizontalOptions" Value="Center" />
    </Style>

</ResourceDictionary>
